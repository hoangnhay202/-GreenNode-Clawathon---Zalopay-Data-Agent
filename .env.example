# ─────────────────────────────────────────────────────────
# LLM Configuration (OpenAI-compatible provider)
# ─────────────────────────────────────────────────────────
# OPTION 1: GreenNode AI Platform (recommended)
#   /agentbase-llm → get API key + list models
LLM_API_KEY=
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_MODEL=

# OPTION 2: OpenAI
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# OPTION 3: OpenRouter
# LLM_API_KEY=sk-or-v1-...
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=openai/gpt-4o

# OPTION 4: Other OpenAI-compatible provider
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=

# ─────────────────────────────────────────────────────────
# Microsoft Teams Bot Framework
# ─────────────────────────────────────────────────────────
# Azure Bot registration (https://portal.azure.com → Bot Services)
TEAMS_APP_ID=
TEAMS_CLIENT_SECRET=
TEAMS_TENANT_ID=

# Optional: shared secret for incoming webhook auth (Bearer token validation)
TEAMS_WEBHOOK_SECRET=

# Fallback for scheduled jobs (if serviceUrl not available in payload)
TEAMS_SERVICE_URL=https://smba.trafficmanager.net/apac/

# ─────────────────────────────────────────────────────────
# AgentBase Memory (conversation history + long-term facts)
# ─────────────────────────────────────────────────────────
# Leave empty → MemorySaver (in-process, resets on restart)
# Set to memory ID → AgentBaseMemoryEvents (platform persistence, survives restarts)
# Create a memory store: /agentbase-memory create (requires IAM credentials)
AGENTBASE_MEMORY_ID=

# Strategy ID for long-term memory (created with the memory store)
# Default "default" maps to the first strategy in the memory store
MEMORY_STRATEGY_ID=default

# ─────────────────────────────────────────────────────────
# News Sources
# ─────────────────────────────────────────────────────────
# Comma-separated RSS feed URLs (leave empty = TechCrunch + Hacker News)
NEWS_RSS_FEEDS=

# ─────────────────────────────────────────────────────────
# Scheduler
# ─────────────────────────────────────────────────────────
# SQLite DB path for APScheduler job persistence
# Mount a volume at /app/data in Docker for persistence across restarts
SCHEDULER_DB_URL=sqlite:///data/jobs.sqlite

# ─────────────────────────────────────────────────────────
# Optional / Debug
# ─────────────────────────────────────────────────────────
# Allow shell command execution via run_cmd tool (DANGEROUS)
ALLOW_RUN_CMD=false
